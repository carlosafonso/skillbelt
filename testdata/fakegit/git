#!/bin/sh
# Fake git for tests. Records calls and simulates side effects.
# Usage: called by manager tests via PATH injection.

LOGFILE="${FAKEGIT_LOG:-/tmp/fakegit.log}"
echo "$@" >> "$LOGFILE"

case "$1" in
  clone)
    # git clone [flags...] <url> <dest>
    for DEST in "$@"; do :; done  # POSIX way to get last argument
    mkdir -p "$DEST"
    echo "fake-cloned" > "$DEST/SKILL.md"
    ;;
  -C)
    # git -C <dir> <subcommand> [args...]
    DIR="$2"
    SUBCMD="$3"
    case "$SUBCMD" in
      pull)
        if [ ! -d "$DIR" ]; then
          echo "error: not a git repository" >&2
          exit 1
        fi
        ;;
      sparse-checkout)
        # git -C <dir> sparse-checkout set <subdir>
        SUBDIR="$5"
        mkdir -p "$DIR/$SUBDIR"
        ;;
      *)
        echo "fakegit: unknown -C subcommand: $SUBCMD" >&2
        exit 1
        ;;
    esac
    ;;
  *)
    echo "fakegit: unknown command: $*" >&2
    exit 1
    ;;
esac
exit 0
